<button
    id="start-button"
    class="border-2 border-violet-900 hover:border-violet-500 focus:border-violet-500 focus:outline-none cursor-pointer text-white font-[--font-lexend] py-2 px-2 h-fit text-2xl w-full resize-none"
>
    Start
</button>

<script>
    const startButton = document.getElementById('start-button');
    const textInput = document.getElementById('reader-text') as HTMLTextAreaElement;
    const speedNumber = document.getElementById('speed-number') as HTMLInputElement;

    startButton?.addEventListener('click', () => {
        const text = textInput?.value || textInput?.placeholder || "";
        const speed = parseInt(speedNumber?.value || "300");

        window.dispatchEvent(new CustomEvent('startReading', {
            detail: { text, speed }
        }));
    });
</script>