<div class="flex flex-col gap-2">
    <span class="text-2xl">Speed:</span>
    <div
        class="border-2 flex gap-2 border-violet-900 focus-within:border-violet-500 px-2 py-1"
    >
        <input
            id="speed-number"
            type="number"
            class="focus:outline-none [appearance:textfield] w-full"
            value="300"
        />
        <span class="shrink-0"> Words Per Minute</span>
    </div>
    <input
        id="speed-range"
        type="range"
        min="60"
        step="30"
        max="1020"
        value="300"
        class="w-full accent-violet-700 hover:accent-violet-600 cursor-pointer focus:outline-none focus:ring-2 focus:ring-violet-500 focus:ring-offset-2"
    />
</div>

<script src="../../../../logic/app/configure/SyncSpeed.js"></script>