---
---

<div id="reader-overlay" class="hidden fixed inset-0 bg-mauve-900 z-50 flex flex-col items-center justify-center">
    <div class="w-full max-w-4xl px-10 flex flex-col items-center gap-12">
        <div class="w-full h-48 border-y-2 border-violet-900 flex items-center justify-center relative">
            <!-- Focus marks -->
            <div class="absolute left-1/2 -top-2 -translate-x-1/2 w-0.5 h-4 bg-violet-500"></div>
            <div class="absolute left-1/2 -bottom-2 -translate-x-1/2 w-0.5 h-4 bg-violet-500"></div>
            
            <div id="reader-word-container" class="text-8xl font-mono text-white flex">
                <div id="word-left" class="text-right min-w-[50%]"></div>
                <div id="word-focus" class="text-red-400"></div>
                <div id="word-right" class="text-left min-w-[50%]"></div>
            </div>
        </div>
        
        <div class="flex gap-4">
            <button id="reader-pause" class="px-6 py-2 border-2 border-violet-900 text-white hover:border-violet-500 cursor-pointer">Pause</button>
            <button id="reader-close" class="px-6 py-2 border-2 border-violet-900 text-white hover:border-violet-500 cursor-pointer">Close</button>
        </div>

        <div class="w-full bg-violet-900/30 h-2 rounded-full overflow-hidden">
            <div id="reader-progress" class="bg-violet-500 h-full w-0 transition-all duration-200"></div>
        </div>
    </div>
</div>

<script>
    import { getFormat } from '../../../logic/app/reader/formater/GetFormat.js';

    const overlay = document.getElementById('reader-overlay');
    const wordLeft = document.getElementById('word-left');
    const wordFocus = document.getElementById('word-focus');
    const wordRight = document.getElementById('word-right');
    const pauseBtn = document.getElementById('reader-pause');
    const closeBtn = document.getElementById('reader-close');
    const progressBar = document.getElementById('reader-progress');

    let formattedWords: { before: string; opr: string; after: string }[] = [];
    let currentIndex = 0;
    let speed = 300;
    let isPaused = false;
    let interval: number | undefined;

    function updateDisplay() {
        if (!wordLeft || !wordFocus || !wordRight || !progressBar) return;
        if (currentIndex >= formattedWords.length) {
            stopReader();
            return;
        }

        const word = formattedWords[currentIndex];
        
        wordLeft.textContent = word.before;
        wordFocus.textContent = word.opr;
        wordRight.textContent = word.after;
        
        const progress = ((currentIndex + 1) / formattedWords.length) * 100;
        progressBar.style.width = `${progress}%`;
    }

    function startReader() {
        if (interval) clearInterval(interval);
        isPaused = false;
        if (pauseBtn) pauseBtn.textContent = 'Pause';

        const msPerWord = (60 / speed) * 1000;
        
        interval = setInterval(() => {
            if (isPaused) return;
            updateDisplay();
            currentIndex++;
        }, msPerWord);
    }

    function stopReader() {
        if (interval) clearInterval(interval);
        interval = undefined;
    }

    window.addEventListener('startReading', (e: any) => {
        const text = e.detail.text;
        speed = e.detail.speed;
        
        formattedWords = getFormat(text);
        currentIndex = 0;
        
        if (formattedWords.length === 0) return;

        overlay?.classList.remove('hidden');
        startReader();
    });

    pauseBtn?.addEventListener('click', () => {
        isPaused = !isPaused;
        pauseBtn.textContent = isPaused ? 'Resume' : 'Pause';
    });

    closeBtn?.addEventListener('click', () => {
        stopReader();
        overlay?.classList.add('hidden');
    });

    // Keyboard controls
    window.addEventListener('keydown', (e) => {
        if (overlay?.classList.contains('hidden')) return;

        if (e.code === 'Space') {
            e.preventDefault();
            pauseBtn?.click();
        } else if (e.code === 'Escape') {
            closeBtn?.click();
        }
    });
</script>